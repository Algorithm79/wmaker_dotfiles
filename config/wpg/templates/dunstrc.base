[colors]
	background = "{color0}"
	foreground = "{color15}"

[global]
    font = "Font Awesome 5 Free Regular 14, CaskaydiaCove Nerd Font Light 13"
    allow_markup = yes
    markup = yes
    sort = yes
    indicate_hidden = yes
    bounce_freq = 0
    show_age_threshold = 60
    word_wrap = yes
    ignore_newline = false
    origin = bottom-center
    transparency = 0
    idle_threshold = 120
    monitor = 0
    follow = mouse
    sticky_history = yes
    line_height = 0
    separator_height = 1
    padding = 12
    horizontal_padding = 12
    separator_width = 1
    gap_size = 5
    startup_notification = false
    frame_width = 1
    width = 400
    progress_bar_max_width = 400
    progress_bar_min_width = 400
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_corner_radius = 5
    scale = 1
    min_icon_size = 64
    max_icon_size = 64
    alignment = center
    vertical_alignment = center

    ### Icons ###
    icon_position = left
    max_icon_size = 64
    icon_path = .icons/flattrcolor/status/24:.icons/flattrcolor/devices/48:.icons/flattrcolor/apps/scalable:.icons/flattrcolor/actions/scalable

    ### History ###
    sticky_history = yes
    history_length = 20

    ### Misc/Advanced ###
    dmenu = /usr/bin/rofi -show run -p dunst:
    browser = /usr/bin/firefox
    always_run_script = true
    title = Dunst
    class = Dunst
    force_xinerama = false

[experimental]
    per_monitor_dpi = false

[urgency_low]
    timeout = 10

[urgency_normal]
    timeout = 10

[urgency_critical]
    frame_color = "{color9}"
    timeout = 0
